{
  "name": "@plasius/player-system-demo-viewer",
  "version": "0.1.0",
  "description": "3D System demo viewer and scenario manifest surface for Player System demos",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:package && npm run build:web",
    "build:package": "tsup",
    "build:web": "vite build",
    "dev": "vite --host 127.0.0.1",
    "render:video": "node scripts/render-demo-video.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:eslint": "eslint . --max-warnings=0",
    "audit:deps": "npm ls --all --omit=optional --omit=peer > /dev/null 2>&1 || true",
    "audit:npm": "npm audit --audit-level=high --omit=dev",
    "audit:test": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build:package",
    "clean": "rimraf dist web-dist",
    "test:coverage": "vitest run --coverage",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build:package && npm run pack:check"
  },
  "keywords": [
    "plasius",
    "player-system",
    "demo",
    "validation",
    "scenarios",
    "typescript"
  ],
  "author": "Plasius LTD <development@plasius.co.uk>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/player-system-demo-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/Plasius-LTD/player-system-demo-viewer/issues"
  },
  "homepage": "https://github.com/Plasius-LTD/player-system-demo-viewer#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@plasius/gpu-interaction": "file:../gpu-interaction",
    "@plasius/gpu-lighting": "file:../gpu-lighting",
    "@plasius/gpu-renderer": "file:../gpu-renderer",
    "@types/node": "^25.7.0",
    "@types/webxr": "^0.5.24",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/plasiusltd/membership"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/Plasius-LTD"
    }
  ],
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "engines": {
    "node": ">=24"
  }
}
